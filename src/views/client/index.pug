            div#responseMsg(class="mt-4 hidden p-4 rounded-xl text-center font-semibold")

  script.
    // Lắng nghe hành vi form
    const form = document.getElementById('contactForm');
    const responseMsg = document.getElementById('responseMsg');
    
    // Gửi dạng đăng ký chính hoặc phụ
    const sendData = async (type) => {
      const name = document.getElementById('name').value;
      const phone = document.getElementById('phone').value;
      const email = document.getElementById('email').value;
      const message = document.getElementById('message').value;

      if (!name || !phone || !message) {
        alert('Vui lòng điền đầy đủ thông tin bắt buộc.');
        return;
      }

      const data = { name, phone, email, message, registerType: type };
      
      try {
        const response = await fetch('/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        
        const result = await response.json();
        
        responseMsg.classList.remove('hidden', 'bg-red-100', 'text-red-800', 'bg-green-100', 'text-green-800');
        if (result.status === 'success') {
          responseMsg.classList.add('bg-green-100', 'text-green-800');
          responseMsg.innerText = result.message + ` (${type === 'primary' ? 'Đăng ký hành trình 7 ngày' : 'Yêu cầu tư vấn Mentor'})`;
          form.reset();
        } else {
          responseMsg.classList.add('bg-red-100', 'text-red-800');
          responseMsg.innerText = 'Đã xảy ra lỗi hệ thống. Vui lòng thử lại sau.';
        }
      } catch (err) {
        responseMsg.classList.remove('hidden');
        responseMsg.classList.add('bg-red-100', 'text-red-800');
        responseMsg.innerText = 'Không kết nối được đến máy chủ.';
      }
    };

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      sendData('primary');
    });

    document.getElementById('btnSecondary').addEventListener('click', () => {
      sendData('mentor');
    });
