doctype html
html(lang="vi")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title #{title || 'Admin - Hôn Nhân Hạnh Phúc'}
    script(src="https://cdn.tailwindcss.com")
  body.bg-slate-100.font-sans
    div.min-h-screen.flex
      // Sidebar
      aside.w-64.bg-slate-900.text-slate-300.flex.flex-col
        div.p-6.text-2xl.font-extrabold.text-white.border-b.border-slate-800.text-center
          | HNHP Admin
        nav.flex-1.p-4.space-y-2
          a.block.px-4.py-2.5.rounded-lg.bg-slate-800.text-white.font-semibold(href="/admin")
            | 📊 Dashboard
          a.block.px-4.py-2.5.rounded-lg.hover_bg-slate-800.transition(href="#")
            | 👥 Khách hàng đăng ký
          a.block.px-4.py-2.5.rounded-lg.hover_bg-slate-800.transition(href="#")
            | ⚙️ Cài đặt
        div.p-4.border-t.border-slate-800
          a.block.text-center.py-2.rounded-lg.bg-rose-600.hover_bg-rose-700.text-white.font-bold(href="/")
            | Xem trang chủ
      
      // Main Content Area
      div.flex-1.flex.flex-col
        header.bg-white.shadow-sm.py-4.px-8.flex.justify-between.items-center
          h2.text-xl.font-bold.text-slate-800 Trang quản trị
          span.text-slate-600 Xin chào, Quản trị viên
        
        main.p-8.flex-1
          block content
